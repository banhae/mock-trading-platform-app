# Local docker-compose demo only. Do NOT reuse these values anywhere else.
# Copy to .env (same directory) before running compose:
#   cp .env.example .env

POSTGRES_USER=exchange
POSTGRES_PASSWORD=exchange
POSTGRES_DB=exchange

# DEV_MODE=true is hard-coded in docker-compose.demo.yml, but in case you
# disable it, JWT_SECRET must be a non-empty value.
JWT_SECRET=dev-secret-change-me
